import { screen } from '@testing-library/react';
import { http, HttpResponse } from 'msw';
import { setupServer } from 'msw/node';
import {
  registerMswTestHooks,
  renderInTestApp,
} from '@backstage/frontend-test-utils';
import { TodoPage } from './TodoPage';

describe('TodoPage', () => {
  const server = setupServer();
  registerMswTestHooks(server);

  it('renders todos from the backend', async () => {
    server.use(
      http.get('*/api/{{pluginId}}/todos', () =>
        HttpResponse.json({
          items: [
            { id: '1', title: 'Mocked task', createdBy: 'user:default/guest', createdAt: '2025-01-01T00:00:00.000Z' },
          ],
        }),
      ),
    );

    await renderInTestApp(<TodoPage />);

    expect(await screen.findByText('Mocked task')).toBeInTheDocument();
  });

  it('renders an error when the backend fails', async () => {
    server.use(
      http.get('*/api/{{pluginId}}/todos', () =>
        new HttpResponse(null, { status: 500, statusText: 'Internal Server Error' }),
      ),
    );

    await renderInTestApp(<TodoPage />);

    expect(await screen.findByText(/Failed to fetch todos/)).toBeInTheDocument();
  });
});
